{
  "expo": {
    "name": "Get A Whiff",
    "slug": "getawhiff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.getawhiff.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Get A Whiff needs camera access to scan product barcodes.",
        "NSPhotoLibraryUsageDescription": "Get A Whiff needs photo access to scan barcodes from images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.getawhiff.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Get A Whiff needs camera access to scan product barcodes."
        }
      ],
      "expo-font"
    ],
    "scheme": "getawhiff"
  }
}
